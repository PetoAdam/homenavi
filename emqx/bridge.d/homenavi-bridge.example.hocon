## Example local bridge configuration for Homenavi EMQX.
##
## Copy this file to any name ending in `.hocon` inside `emqx/bridge.d/`.
## Every `*.hocon` file in that directory is concatenated at container startup.
##
## Example:
##   cp emqx/bridge.d/homenavi-bridge.example.hocon emqx/bridge.d/10-pi-bridge.hocon
##
## Keep topic directions explicit to avoid command/state loops.

## connectors {
##   mqtt {
##     remote_out {
##       enable = true
##       server = "broker.example.internal:1883"
##       pool_size = 1
##       clientid_prefix = "homenavi_remote_out"
##       proto_ver = v4
##       bridge_mode = false
##       clean_start = true
##       keepalive = 60s
##       retry_interval = 15s
##       max_inflight = 32
##       ssl {
##         enable = false
##       }
##       resource_opts {
##         health_check_interval = 15s
##         start_after_created = true
##         start_timeout = 10s
##       }
##     }
##
##     remote_in {
##       enable = true
##       server = "broker.example.internal:1883"
##       pool_size = 1
##       clientid_prefix = "homenavi_remote_in"
##       proto_ver = v4
##       bridge_mode = false
##       clean_start = true
##       keepalive = 60s
##       retry_interval = 15s
##       max_inflight = 32
##       ssl {
##         enable = false
##       }
##       resource_opts {
##         health_check_interval = 15s
##         start_after_created = true
##         start_timeout = 10s
##       }
##     }
##   }
## }
##
## actions {
##   mqtt {
##     remote_control_out {
##       enable = true
##       connector = "remote_out"
##       parameters {
##         topic = "${topic}"
##         qos = "${qos}"
##         retain = "${flags.retain}"
##         payload = "${payload}"
##       }
##     }
##   }
## }
##
## sources {
##   mqtt {
##     remote_hdp_state {
##       enable = true
##       connector = "remote_in"
##       parameters {
