# JWT keys for RS256
# Note: auth-service only needs JWT_PRIVATE_KEY_PATH (for signing tokens)
#       api-gateway only needs JWT_PUBLIC_KEY_PATH (for verifying tokens)
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem

# -----------------------------
# Ports (compose interpolation)
# -----------------------------
# Container/listen ports (inside Docker network)
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8000
USER_SERVICE_PORT=8001
EMAIL_SERVICE_PORT=8002
PROFILE_PICTURE_SERVICE_PORT=8000
DEVICE_HUB_PORT=8090
ENTITY_REGISTRY_PORT=8095
ZIGBEE_ADAPTER_PORT=8091
MOCK_ADAPTER_PORT=8092
MATTER_ADAPTER_PORT=8096
HISTORY_SERVICE_PORT=8093
AUTOMATION_SERVICE_PORT=8094
WEATHER_SERVICE_PORT=8095

FRONTEND_CONTAINER_PORT=80
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14268
REDIS_PORT=6379
MQTT_PORT=1883
MQTT_WS_PORT=9001
ZIGBEE2MQTT_UI_PORT=8081

# Host-exposed ports
FRONTEND_HOST_PORT=5173
API_GATEWAY_HOST_PORT=8080
NGINX_HOST_PORT=80
NGINX_HOST_PORT_PI=81
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
JAEGER_UI_HOST_PORT=16686
JAEGER_COLLECTOR_HOST_PORT=14268
MQTT_HOST_PORT=1883
MQTT_WS_HOST_PORT=9001
ZIGBEE2MQTT_UI_HOST_PORT=8081

# Default internal MQTT wiring used by services and the API gateway's `/ws/hdp` proxy.
MQTT_BROKER_URL=mqtt://emqx:1883
MQTT_WEBSOCKET_UPSTREAM_URL=ws://emqx:8083/mqtt

# Hosts (compose uses service DNS names; URLs are built from *_HOST + *_PORT)
AUTH_SERVICE_HOST=auth-service
USER_SERVICE_HOST=user-service
EMAIL_SERVICE_HOST=email-service
PROFILE_PICTURE_SERVICE_HOST=profile-picture-service
DEVICE_HUB_HOST=device-hub
ENTITY_REGISTRY_HOST=entity-registry-service
REDIS_HOST=redis
JAEGER_HOST=jaeger
MQTT_HOST=emqx

# Profile pictures default to bundled MinIO-backed S3 storage.
# Set the three sensitive values below before running Compose.
# Example: `openssl rand -hex 16` for the access key and `openssl rand -hex 32` for the secret values.
PROFILE_PICTURE_STORAGE_TYPE=s3
PROFILE_PICTURE_STORAGE_S3_ENDPOINT=http://minio:9000
PROFILE_PICTURE_STORAGE_S3_REGION=us-east-1
PROFILE_PICTURE_STORAGE_S3_BUCKET=profile-pictures
PROFILE_PICTURE_STORAGE_S3_ACCESS_KEY=
PROFILE_PICTURE_STORAGE_S3_SECRET_KEY=
PROFILE_PICTURE_STORAGE_S3_FORCE_PATH_STYLE=true

LOG_LEVEL=info

# Integrations
# Path to your deployment-local installed integrations config.
# If unset, docker-compose defaults to ./integrations/config/installed.example.yaml
# INTEGRATIONS_CONFIG_FILE=./integrations/config/installed.yaml

# Matter adapter / OTBR controller
# Controller device: SMLIGHT Thread+OTBR running on-device at http://192.168.64.144
# OTBR page indicates state=leader and exposes a REST-managed OTBR.
MATTER_THREAD_BORDER_ROUTER_HOST=192.168.64.144
MATTER_THREAD_BORDER_ROUTER_PORT=8080
MATTER_THREAD_DATASET_SOURCE=otbr
MATTER_THREAD_OPERATIONAL_DATASET_HEX=hex:0e080000000000010000000300000f4a0300001a35060004001fffe00208dead00beef00cafe0708fd000db800a00000051000112233445566778899aabbccddeeff030e4f70656e5468726561642d455350010212340410104810e2315100afd6bc9215a6bfac530c0402a0f7f8
MATTER_ADAPTER_ENABLED=true
MATTER_ADAPTER_ID=matter-adapter-1
MATTER_ADAPTER_VERSION=dev
MATTER_DEFAULT_PAIRING_TIMEOUT_SEC=300
MATTER_DEFAULT_NETWORK_PATH=on_network
MATTER_ENABLE_ON_NETWORK=true
MATTER_ENABLE_BLE=true
MATTER_ENABLE_THREAD=true
MATTER_COMMISSIONING_INTERFACE=auto
MATTER_OTBR_BASE_URL=http://192.168.64.144
MATTER_OTBR_EXPECTED_STATE=leader
MATTER_THREAD_DATASET_SOURCE=otbr
# TLVs copied from the OTBR page. The adapter accepts the hex:-prefixed value directly.
# Keep this as a fallback even when MATTER_THREAD_DATASET_SOURCE=otbr.
MATTER_THREAD_OPERATIONAL_DATASET_HEX=hex:0e080000000000010000000300000f4a0300001a35060004001fffe00208dead00beef00cafe0708fd000db800a00000051000112233445566778899aabbccddeeff030e4f70656e5468726561642d455350010212340410104810e2315100afd6bc9215a6bfac530c0402a0f7f8
# Matter commissioner sidecar + wrapper. The adapter invokes the wrapper, which forwards pairing to the sidecar service.
MATTER_COMMISSIONER_ENABLED=true
MATTER_COMMISSIONER_COMMAND=/app/bin/matter-commissioner-wrapper
MATTER_COMMISSIONER_ARGS=
MATTER_COMMISSIONER_URL=http://matter-commissioner:8098
MATTER_COMMISSIONER_TIMEOUT=2m
MATTER_COMMISSIONER_PORT=8098
# Real backend command inside the commissioner container. It expects a chip-tool binary to be installed or mounted.
MATTER_COMMISSIONER_BACKEND_COMMAND=/app/bin/chip-tool-wrapper
MATTER_COMMISSIONER_BACKEND_ARGS=
MATTER_COMMISSIONER_BACKEND_TIMEOUT=2m
CHIP_TOOL_BINARY=/usr/bin/chip-tool
CHIP_TOOL_STORAGE_DIR=/var/lib/matter-commissioner/chip-tool
CHIP_TOOL_COMMISSIONER_NAME=alpha
CHIP_TOOL_COMMISSIONER_NODEID=
CHIP_TOOL_PAA_TRUST_STORE_PATH=
CHIP_TOOL_CD_TRUST_STORE_PATH=
CHIP_TOOL_BYPASS_ATTESTATION_VERIFIER=false
CHIP_TOOL_EXTRA_ARGS=

NGINX_MODE=dev
NGINX_CERT_ORIGIN=./nginx/certs/nginx.crt
NGINX_KEY_ORIGIN=./nginx/certs/nginx.key
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=users
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Optional secrets (used by some services)
REDIS_PASSWORD=

# history-service
# Leave blank to auto-generate a unique MQTT client id per process/pod.
HISTORY_SERVICE_MQTT_CLIENT_ID=
HISTORY_INGEST_RETAINED=false
HISTORY_HDP_STATE_PREFIX=homenavi/hdp/device/state/

# automation-service
# Leave blank to auto-generate a unique MQTT client id per process/pod.
AUTOMATION_SERVICE_MQTT_CLIENT_ID=

# weather-service
OPENWEATHER_API_KEY=
WEATHER_CACHE_TTL_MINUTES=15

# Frontend marketplace
VITE_MARKETPLACE_API_BASE=https://marketplace.homenavi.org

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost/api/auth/oauth/google/callback # Note: This should match the redirect URI configured in Google Cloud Console

# Email Service Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# This is an application-specific password generated from your Google account
# If you have 2FA enabled, you need to create an app password
# If you don't have 2FA, you can use your regular password, but it's not recommended
# For more info: https://support.google.com/accounts/answer/185833?visit_id=638889089789065316-2791022060&p=InvalidSecondFactor&rd=1
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Homenavi
