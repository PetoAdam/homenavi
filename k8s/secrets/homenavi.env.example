# Copy this file to a local .env (or another local path) and fill real values.
# Do not commit real secrets.

# Weather service
OPENWEATHER_API_KEY=
WEATHER_CACHE_TTL_MINUTES=15

# Google OAuth (auth-service)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost/api/auth/oauth/google/callback

# SMTP (email-service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=Homenavi

# Shared infra credentials (keep aligned with chart/default DB user if changed)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=users
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Optional redis auth
REDIS_PASSWORD=
